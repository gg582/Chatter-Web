# Example environment configuration for the Chatter BBS terminal bridge
# Copy this file to .env or export the variables before launching the server.

# Protocol option: telnet only
CHATTER_BBS_PROTOCOL=telnet

# Hostname or IP address of the upstream BBS/telnet server
CHATTER_BBS_HOST=chatter.pw

# Port exposed by the upstream TELNET server
CHATTER_BBS_PORT=2323

# Optional defaults that appear in the connection drawer when no server host is set
CHATTER_BBS_HOST_DEFAULT=chatter.pw
CHATTER_BBS_PORT_DEFAULT=2323

# Optional preset username for the login gate
CHATTER_BBS_SSH_USER=bbsop

# Optional placeholder text shown in the host input when unset
CHATTER_BBS_HOST_PLACEHOLDER="bbs.example.com"

# Optional placeholder text shown in the host input when unset
